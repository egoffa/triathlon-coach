FROM ollama/ollama:latest

EXPOSE 11434

# Default to llama2 but can be overridden
ENV MODEL=llama2:7b

# Health check to verify Ollama is ready
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:11434/api/tags || exit 1

# Create entrypoint script that pulls the model on startup
RUN mkdir -p /app
COPY config/ollama_models.txt /app/

ENTRYPOINT ["/bin/bash"]
CMD ["-c", "ollama serve & sleep 10 && ollama pull ${MODEL} && wait"]
